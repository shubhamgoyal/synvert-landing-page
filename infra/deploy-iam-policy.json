{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DeploySync",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:ListBucket",
        "s3:DeleteObject"
      ],
      "Resource": [
        "arn:aws:s3:::synvertchem.com",
        "arn:aws:s3:::synvertchem.com/*"
      ]
    },
    {
      "Sid": "InvalidateCache",
      "Effect": "Allow",
      "Action": "cloudfront:CreateInvalidation",
      "Resource": "arn:aws:cloudfront::983491056638:distribution/E3ED8YEX4MLX1A"
    }
  ]
}
